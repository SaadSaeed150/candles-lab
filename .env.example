# Django
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# PostgreSQL / TimescaleDB
POSTGRES_DB=trading_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Exchange API keys (keep these secret!)
BINANCE_API_KEY=
BINANCE_API_SECRET=
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Trading data collection — Crypto (Binance)
TRADING_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,LINKUSDT,DOTUSDT
TRADING_DEFAULT_TIMEFRAME=1m
ORDER_BOOK_DEPTH_LIMIT=20
DATA_COLLECTION_INTERVAL_SECONDS=60

# Forex data collection — Twelve Data (sign up free at https://twelvedata.com)
TWELVEDATA_API_KEY=
FOREX_SYMBOLS=EUR/USD,USD/JPY,GBP/USD,AUD/USD,USD/CAD,USD/CHF,NZD/USD,EUR/GBP,EUR/JPY,GBP/JPY
FOREX_POLL_INTERVAL_SECONDS=300

# US Stock data collection — Polygon.io (sign up free at https://polygon.io)
# Provides OHLCV + VWAP + trade count + NBBO bid/ask quotes
POLYGON_API_KEY=
STOCK_SYMBOLS=AAPL,MSFT,NVDA,GOOGL,AMZN,META,TSLA,JPM,V,AVGO
STOCK_POLL_INTERVAL_SECONDS=60

# Finnhub — US Stocks fallback (sign up free at https://finnhub.io)
FINNHUB_API_KEY=
